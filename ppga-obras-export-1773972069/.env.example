# ============================================
# PPGA OBRAS - Configurações de Ambiente
# ============================================

# Banco de Dados MySQL
# Formato: mysql://usuario:senha@host:porta/banco_de_dados
DATABASE_URL=mysql://ppga:ppga_password@localhost:3306/ppga_obras

# Node Environment
NODE_ENV=production

# Porta do Servidor
PORT=3000

# URL da Aplicação (para links de email, etc)
APP_URL=http://localhost:3000

# OpenAI API Key (opcional, se usar integração com IA)
OPENAI_API_KEY=sua_chave_aqui

# AWS S3 (opcional, se usar upload de arquivos)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# ============================================
# INSTRUÇÕES:
# ============================================
# 1. Copie este arquivo para .env.local
# 2. Preencha as variáveis com seus valores
# 3. Nunca compartilhe o arquivo .env.local
# 4. Mantenha este arquivo .env.example no repositório
